<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="default"/>
<meta name="apple-mobile-web-app-title" content="Cycle Tracker"/>
<meta name="theme-color" content="#F6339A"/>
<title>Cycle Tracker</title>
<link rel="manifest" href="manifest.json"/>
<link rel="apple-touch-icon" href="icon-192.png"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
<style>
:root{--r:18px;--rs:10px;--bg:#f8f7f5;--card:#fff;--border:rgba(0,0,0,0.08);--text:#1a1a1a;--text2:#666;--text3:#999}
@media(prefers-color-scheme:dark){:root{--bg:#111;--card:#1e1e1e;--border:rgba(255,255,255,0.1);--text:#f0f0f0;--text2:#aaa;--text3:#666}}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;font-family:-apple-system,'SF Pro Display',system-ui,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden}
body{padding-bottom:env(safe-area-inset-bottom)}
.nav{position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:0.5px solid var(--border);display:flex;padding:6px 0 calc(6px + env(safe-area-inset-bottom));z-index:100}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:6px 2px;color:var(--text3);font-size:10px;font-weight:500;transition:color .15s}
.nav-btn i{font-size:21px}
.main{max-width:480px;margin:0 auto;padding:0 0 80px}
.pg{display:none;padding:0 12px}.pg.on{display:block}
.ptitle{font-size:12px;font-weight:500;text-align:center;letter-spacing:.06em;text-transform:uppercase;padding:3.5rem 0 .8rem}

.profile-card{border-radius:var(--r);margin-bottom:12px;overflow:hidden;background:#96F7E4}
.prof-top{padding:16px 18px 14px;display:flex;align-items:center;gap:14px;cursor:pointer}
.prof-av{width:52px;height:52px;border-radius:50%;background:rgba(0,0,0,.1);display:flex;align-items:center;justify-content:center;font-size:22px;color:#085041;flex-shrink:0}
.prof-name{font-size:17px;font-weight:500;color:#04342C}
.prof-meta{font-size:12px;color:#0F6E56;margin-top:2px}
.prof-arrow{margin-left:auto;font-size:18px;color:#0F6E56;transition:transform .2s}
.prof-arrow.open{transform:rotate(180deg)}
.prof-stats{display:flex;gap:1px;border-top:0.5px solid rgba(0,0,0,.1)}
.ps{flex:1;padding:11px 8px;text-align:center;background:rgba(255,255,255,.3)}
.ps-num{font-size:16px;font-weight:500;color:#04342C}
.ps-lbl{font-size:10px;color:#0F6E56;margin-top:2px}
.bmi-wrap{height:10px;border-radius:99px;background:rgba(0,0,0,.12);overflow:hidden;position:relative;margin:10px 0 4px}
.bmi-fill{height:10px;border-radius:99px;background:rgba(4,52,44,.6);transition:width .4s}
.bmi-mark{position:absolute;top:-3px;width:2px;height:16px;background:#04342C;border-radius:99px;transition:left .4s}
.bmi-lbls{display:flex;justify-content:space-between;font-size:10px;color:#0F6E56}
.bmi-val{font-size:14px;font-weight:500;color:#04342C;margin-top:8px}
.bmi-cat{font-size:12px;color:#0F6E56;margin-top:2px}
.prof-edit{display:none;padding:14px 18px 16px;border-top:0.5px solid rgba(0,0,0,.1)}
.prof-edit.open{display:block}
.erow{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.elbl{font-size:12px;color:#0F6E56;min-width:64px;flex-shrink:0}
.einp{flex:1;background:rgba(255,255,255,.5);border:0.5px solid rgba(4,52,44,.25);border-radius:9px;padding:7px 11px;font-size:13px;color:#04342C;outline:none;font-family:inherit}
.einp::placeholder{color:rgba(4,52,44,.4)}
.eunit{font-size:12px;color:#0F6E56;min-width:28px}
.esave{background:#04342C;border:none;border-radius:10px;padding:8px 18px;font-size:13px;font-weight:500;color:#96F7E4;cursor:pointer;width:100%;margin-top:4px}
.seg{display:flex;gap:1px;background:rgba(0,0,0,.1);border-radius:10px;overflow:hidden;margin-bottom:10px}
.seg-b{flex:1;padding:7px 5px;text-align:center;font-size:12px;color:#0F6E56;background:none;border:none;cursor:pointer}
.seg-b.on{background:rgba(4,52,44,.2);color:#04342C;font-weight:500}

.main-banner{border-radius:var(--r);margin-bottom:12px;background:#F6339A}
.banner-body{padding:18px 18px 16px;position:relative}
.banner-title{font-size:20px;font-weight:500;color:#fff;margin-bottom:3px}
.banner-sub{font-size:12px;color:rgba(255,255,255,.82)}
.banner-stats{display:flex;gap:10px;margin-top:14px}
.bstat{background:rgba(255,255,255,.2);border-radius:12px;padding:10px 14px;flex:1}
.bstat-num{font-size:24px;font-weight:500;color:#fff}
.bstat-lbl{font-size:11px;color:rgba(255,255,255,.78);margin-top:2px}
.phase-pill{display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.2);border-radius:99px;padding:5px 13px;font-size:12px;color:#fff;margin-top:11px}
.ci{position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:52px;opacity:.18;pointer-events:none;color:#fff}
.period-btn{width:100%;padding:13px;border-radius:14px;border:none;font-size:14px;font-weight:500;cursor:pointer;margin-bottom:12px;display:flex;align-items:center;justify-content:center;gap:7px;background:#F6339A;color:#fff}
.period-btn.end{background:#FFE4F3;color:#8B0050;border:0.5px solid #F6339A}

.panel{background:var(--card);border:0.5px solid var(--border);border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.panel-head{padding:12px 15px;border-bottom:0.5px solid var(--border);font-size:13px;font-weight:500;display:flex;align-items:center;gap:6px}
.panel-body{padding:13px 15px}
.upcoming-panel .panel-head{background:#53EAFD;color:#0A4F5C}
.upcoming-panel .panel-head i{color:#0A4F5C}
.todaylog-panel .panel-head{background:#36BBA7;color:#fff}
.todaylog-panel .panel-head i{color:#fff}

.cal-inner{background:#FDA5D5;border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.cal-top{padding:12px 14px 6px;display:flex;align-items:center;justify-content:space-between;background:#FDA5D5}
.cal-mo{font-size:14px;font-weight:500;color:#6B0040}
.cal-nav{background:rgba(255,255,255,.5);border:0.5px solid rgba(107,0,64,.2);border-radius:8px;padding:4px 8px;cursor:pointer;color:#6B0040;font-size:12px}
.cgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;padding:4px 10px 10px;background:#FDA5D5}
.cdow{text-align:center;font-size:10px;color:#8B0050;padding:3px 0;font-weight:500}
.cday{aspect-ratio:1;border-radius:9px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;font-size:12px;color:#6B0040;transition:all .1s;position:relative;background:rgba(255,255,255,.45)}
.cday:hover{filter:brightness(.93)}
.cday.tod{box-shadow:0 0 0 2.5px #E7180B}.cday.tod .dno{font-weight:500;color:#E7180B}
.cday.sel{box-shadow:0 0 0 2px #6B0040}
.cday.period{background:#F09595;color:#501313}
.cday.predicted{background:#FAEEDA;color:#633806;border:1.5px dashed #EF9F27}
.cday.follicular{background:#B5D4F4;color:#042C53}
.cday.ovulation{background:#9FE1CB;color:#04342C}
.cday.luteal{background:#CECBF6;color:#26215C}
.cday.om .dno{color:rgba(107,0,64,.35)}
.dno{font-size:12px;line-height:1}
.cdot{width:3px;height:3px;border-radius:50%;position:absolute;bottom:3px;background:#6B0040}
.legend{display:flex;gap:7px;flex-wrap:wrap;padding:6px 14px 12px;background:#FDA5D5}
.leg{display:flex;align-items:center;gap:4px;font-size:11px;color:#6B0040}
.leg-dot{width:10px;height:10px;border-radius:3px;flex-shrink:0}

.phase-info-panel{background:#FB64B6;border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.phase-info-head{padding:12px 15px;border-bottom:0.5px solid rgba(255,255,255,.3);font-size:13px;font-weight:500;color:#fff;display:flex;align-items:center;gap:6px}
.pc{padding:13px 16px;display:flex;align-items:flex-start;gap:11px;border-top:0.5px solid rgba(255,255,255,.25)}
.pc:first-of-type{border-top:none}
.pc-icon{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:18px;background:rgba(255,255,255,.25)}
.pc-name{font-size:13px;font-weight:500;margin-bottom:2px;color:#fff}
.pc-dates{font-size:12px;color:rgba(255,255,255,.85);margin-bottom:3px}
.pc-active{font-size:11px;font-weight:500;margin-bottom:3px;color:rgba(255,255,255,.9)}
.pc-desc{font-size:11px;color:rgba(255,255,255,.8);line-height:1.5}

.log-panel{background:#C27AFF;border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.log-body{padding:16px}
.log-sec{font-size:11px;font-weight:500;color:rgba(255,255,255,.9);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px}
.flow-row{display:flex;gap:7px;margin-bottom:14px}
.fl-btn{flex:1;padding:9px 4px;border-radius:10px;border:0.5px solid rgba(255,255,255,.4);background:rgba(255,255,255,.15);cursor:pointer;font-size:12px;color:rgba(255,255,255,.9);text-align:center}
.fl-btn.on{background:rgba(255,255,255,.9);color:#6B30AA;font-weight:500;border-color:transparent}
.mood-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px}
.mood-btn{padding:9px 5px;border-radius:10px;border:0.5px solid rgba(255,255,255,.3);background:rgba(255,255,255,.15);cursor:pointer;text-align:center;font-size:11px;color:rgba(255,255,255,.9)}
.mood-btn .mi{font-size:18px;display:block;margin-bottom:3px}
.mood-btn.on{background:rgba(255,255,255,.9);color:#6B30AA}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px}
.chip{padding:7px 12px;border-radius:99px;font-size:12px;cursor:pointer;border:0.5px solid rgba(255,255,255,.4);background:rgba(255,255,255,.15);color:rgba(255,255,255,.9)}
.chip.on{background:rgba(255,255,255,.9);border-color:transparent;color:#6B30AA;font-weight:500}
.note-area{width:100%;padding:9px 12px;border-radius:10px;border:0.5px solid rgba(255,255,255,.4);background:rgba(255,255,255,.2);color:#fff;font-size:13px;resize:none;outline:none;margin-bottom:13px;font-family:inherit}
.note-area::placeholder{color:rgba(255,255,255,.55)}
.save-btn{width:100%;padding:12px;border-radius:12px;background:#fff;border:none;color:#6B30AA;font-size:14px;font-weight:500;cursor:pointer}

.ins-panel{background:#2B7FFF;border-radius:var(--r);margin-bottom:12px;overflow:hidden}
.ins-panel-body{padding:14px}
.ins-panel-head{padding:12px 15px;border-bottom:0.5px solid rgba(255,255,255,.25);font-size:13px;font-weight:500;color:#fff;display:flex;align-items:center;gap:6px}
.dentry{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-top:0.5px solid rgba(255,255,255,.2)}
.dentry:first-of-type{border-top:none}
.dentry-dot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0}
.dentry-date{font-size:12px;font-weight:500;color:#fff}
.dentry-sub{font-size:11px;color:rgba(255,255,255,.8);margin-top:2px}
.prog-bar{height:5px;border-radius:99px;background:rgba(255,255,255,.2);overflow:hidden;margin:6px 0}
.prog-fill{height:5px;border-radius:99px}

.set-btn{width:100%;padding:12px;border-radius:var(--rs);border:none;font-size:14px;font-weight:500;cursor:pointer;margin-bottom:8px;display:flex;align-items:center;justify-content:center;gap:7px}
.btn-pink{background:#F6339A;color:#fff}
.btn-outline{background:var(--card);color:var(--text);border:0.5px solid var(--border)}
.notice{background:rgba(246,51,154,0.08);border:0.5px solid rgba(246,51,154,0.25);border-radius:var(--rs);padding:11px 13px;font-size:12px;color:#8B0050;margin-bottom:12px;display:flex;gap:8px}
.arc-item{background:var(--card);border:0.5px solid var(--border);border-radius:var(--rs);padding:12px 15px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
.arc-mo{font-size:14px;font-weight:500;color:var(--text)}
.arc-meta{font-size:12px;color:var(--text2);margin-top:2px}

.toast{position:fixed;top:60px;left:50%;transform:translateX(-50%) translateY(-20px);background:#F6339A;color:#fff;padding:9px 18px;border-radius:99px;font-size:13px;opacity:0;transition:all .3s;z-index:999;pointer-events:none;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.empty{font-size:13px;color:rgba(255,255,255,.7);text-align:center;padding:18px 0}
.empty-d{font-size:13px;color:var(--text3);text-align:center;padding:18px 0}
@media(prefers-color-scheme:dark){.einp,.note-area{color-scheme:dark}}
</style>
</head>
<body>
<div class="main">
  <div class="pg on" id="pg-home">
    <div class="ptitle" style="color:#E7180B" id="today-lbl">Loading...</div>
    <div class="profile-card">
      <div class="prof-top" onclick="toggleProf()">
        <div class="prof-av"><i class="ti ti-user"></i></div>
        <div><div class="prof-name" id="prof-name">My profile</div><div class="prof-meta" id="prof-meta">Tap to set up your profile</div></div>
        <i class="ti ti-chevron-down prof-arrow" id="prof-arrow"></i>
      </div>
      <div class="prof-stats" id="prof-stats" style="display:none"></div>
      <div class="prof-edit" id="prof-edit">
        <div class="erow"><span class="elbl">Name</span><input class="einp" id="e-name" placeholder="Your name" maxlength="30"/></div>
        <div class="erow"><span class="elbl">Age</span><input class="einp" id="e-age" type="number" min="10" max="60" placeholder="25"/><span class="eunit">yrs</span></div>
        <div class="erow"><span class="elbl">Height</span><input class="einp" id="e-height" type="number" placeholder="165"/><span class="eunit" id="h-unit">cm</span></div>
        <div class="erow"><span class="elbl">Weight</span><input class="einp" id="e-weight" type="number" placeholder="60"/><span class="eunit" id="w-unit">kg</span></div>
        <div class="seg"><button class="seg-b on" id="seg-m" onclick="setUnit('metric')">Metric (cm/kg)</button><button class="seg-b" id="seg-i" onclick="setUnit('imperial')">Imperial (in/lbs)</button></div>
        <div id="bmi-prev" style="display:none;margin-bottom:10px">
          <div class="bmi-wrap"><div class="bmi-fill" id="bmi-fill" style="width:0%"></div><div class="bmi-mark" id="bmi-mark" style="left:0%"></div></div>
          <div class="bmi-lbls"><span>Underweight</span><span>Normal</span><span>Overweight</span><span>Obese</span></div>
          <div class="bmi-val" id="bmi-val">BMI: —</div><div class="bmi-cat" id="bmi-cat"></div>
        </div>
        <button class="esave" onclick="saveProf()"><i class="ti ti-check"></i> Save profile</button>
      </div>
    </div>
    <div class="main-banner">
      <div class="banner-body">
        <div class="banner-title" id="b-title">Your cycle</div>
        <div class="banner-sub" id="b-sub">Log your period to start tracking</div>
        <div class="banner-stats" id="b-stats"></div>
        <div class="phase-pill"><i class="ti ti-droplet"></i><span id="b-pill">No data yet</span></div>
        <div class="ci"><i class="ti ti-moon"></i></div>
      </div>
    </div>
    <button class="period-btn" id="period-btn" onclick="togglePeriod()">
      <i class="ti ti-droplet"></i><span id="period-btn-lbl">Period started today</span>
    </button>
    <div class="panel upcoming-panel">
      <div class="panel-head"><i class="ti ti-calendar-event"></i>Upcoming phases</div>
      <div class="panel-body" id="upcoming"><div class="empty-d">Log your period to see phases</div></div>
    </div>
    <div class="panel todaylog-panel">
      <div class="panel-head"><i class="ti ti-notes"></i>Today's log</div>
      <div class="panel-body" id="today-log"><div class="empty-d">Nothing logged today</div></div>
    </div>
    <div style="font-size:11px;color:var(--text3);text-align:center;padding:4px 0" id="stxt"></div>
  </div>

  <div class="pg" id="pg-cal">
    <div class="ptitle" style="color:#996600">Calendar</div>
    <div class="cal-inner">
      <div class="cal-top">
        <button class="cal-nav" onclick="shiftCal(-1)"><i class="ti ti-chevron-left"></i></button>
        <div class="cal-mo" id="cal-mo"></div>
        <button class="cal-nav" onclick="shiftCal(1)"><i class="ti ti-chevron-right"></i></button>
      </div>
      <div class="cgrid" id="cgrid"></div>
      <div class="legend">
        <div class="leg"><div class="leg-dot" style="background:#F09595"></div>Period</div>
        <div class="leg"><div class="leg-dot" style="background:#FAEEDA;border:1.5px dashed #EF9F27"></div>Predicted</div>
        <div class="leg"><div class="leg-dot" style="background:#B5D4F4"></div>Follicular</div>
        <div class="leg"><div class="leg-dot" style="background:#9FE1CB"></div>Ovulation</div>
        <div class="leg"><div class="leg-dot" style="background:#CECBF6"></div>Luteal</div>
      </div>
    </div>
    <div class="phase-info-panel">
      <div class="phase-info-head"><i class="ti ti-info-circle"></i>Cycle phases — dates & info</div>
      <div id="phase-info"><div class="empty">Log your period to see phase dates</div></div>
    </div>
    <div id="cal-detail"></div>
  </div>

  <div class="pg" id="pg-log">
    <div class="ptitle" style="color:#42D3F2">Log today</div>
    <div class="log-panel">
      <div class="log-body">
        <div class="log-sec">Flow</div>
        <div class="flow-row">
          <div class="fl-btn" id="fl-none" onclick="setFlow('none')">None</div>
          <div class="fl-btn" id="fl-light" onclick="setFlow('light')">Light</div>
          <div class="fl-btn" id="fl-medium" onclick="setFlow('medium')">Medium</div>
          <div class="fl-btn" id="fl-heavy" onclick="setFlow('heavy')">Heavy</div>
        </div>
        <div class="log-sec">Mood</div>
        <div class="mood-grid">
          <div class="mood-btn" id="md-happy" onclick="togMood('happy')"><span class="mi"><i class="ti ti-mood-smile"></i></span>Happy</div>
          <div class="mood-btn" id="md-calm" onclick="togMood('calm')"><span class="mi"><i class="ti ti-moon"></i></span>Calm</div>
          <div class="mood-btn" id="md-tired" onclick="togMood('tired')"><span class="mi"><i class="ti ti-zzz"></i></span>Tired</div>
          <div class="mood-btn" id="md-anxious" onclick="togMood('anxious')"><span class="mi"><i class="ti ti-alert-circle"></i></span>Anxious</div>
          <div class="mood-btn" id="md-sad" onclick="togMood('sad')"><span class="mi"><i class="ti ti-mood-sad"></i></span>Sad</div>
          <div class="mood-btn" id="md-irritable" onclick="togMood('irritable')"><span class="mi"><i class="ti ti-flame"></i></span>Irritable</div>
          <div class="mood-btn" id="md-sensitive" onclick="togMood('sensitive')"><span class="mi"><i class="ti ti-heart"></i></span>Sensitive</div>
          <div class="mood-btn" id="md-energetic" onclick="togMood('energetic')"><span class="mi"><i class="ti ti-bolt"></i></span>Energetic</div>
        </div>
        <div class="log-sec">Symptoms</div>
        <div class="chips">
          <div class="chip" id="sy-cramps" onclick="togSym('cramps')">Cramps</div>
          <div class="chip" id="sy-headache" onclick="togSym('headache')">Headache</div>
          <div class="chip" id="sy-bloating" onclick="togSym('bloating')">Bloating</div>
          <div class="chip" id="sy-backpain" onclick="togSym('backpain')">Back pain</div>
          <div class="chip" id="sy-nausea" onclick="togSym('nausea')">Nausea</div>
          <div class="chip" id="sy-breast" onclick="togSym('breast')">Breast tenderness</div>
          <div class="chip" id="sy-acne" onclick="togSym('acne')">Acne</div>
          <div class="chip" id="sy-spotting" onclick="togSym('spotting')">Spotting</div>
          <div class="chip" id="sy-insomnia" onclick="togSym('insomnia')">Insomnia</div>
          <div class="chip" id="sy-cravings" onclick="togSym('cravings')">Cravings</div>
        </div>
        <div class="log-sec">Notes</div>
        <textarea class="note-area" id="log-note" rows="3" placeholder="How are you feeling today?"></textarea>
        <button class="save-btn" onclick="saveLog()"><i class="ti ti-check"></i> Save log</button>
      </div>
    </div>
  </div>

  <div class="pg" id="pg-ins">
    <div class="ptitle" style="color:#2B7FFF">Insights</div>
    <div id="ins-content"><div class="empty-d">Log a few cycles to see insights</div></div>
  </div>

  <div class="pg" id="pg-settings">
    <div class="ptitle" style="color:var(--text2)">Settings</div>
    <div style="margin-bottom:16px">
      <div style="font-size:12px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Your data</div>
      <button class="set-btn btn-pink" onclick="exportData()"><i class="ti ti-download"></i> Export backup (JSON)</button>
      <button class="set-btn btn-outline" onclick="document.getElementById('imp-file').click()"><i class="ti ti-upload"></i> Import backup</button>
      <input type="file" id="imp-file" accept=".json" style="display:none" onchange="importData(event)"/>
    </div>
    <div style="margin-bottom:16px">
      <div style="font-size:12px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Monthly archive</div>
      <div class="notice"><i class="ti ti-info-circle" style="font-size:16px;flex-shrink:0;margin-top:1px"></i><span>Save current month before the new month starts. Calendar resets cleanly.</span></div>
      <button class="set-btn btn-pink" onclick="saveMonth()"><i class="ti ti-device-floppy"></i> Save this month to archive</button>
    </div>
    <div>
      <div style="font-size:12px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px">Archive</div>
      <div id="arc-list"><div class="empty-d">No archived months yet</div></div>
    </div>
  </div>
</div>

<nav class="nav">
  <button class="nav-btn" id="bt-home" onclick="goPage('home')" style="color:#E7180B"><i class="ti ti-heart" style="color:#E7180B"></i>Today</button>
  <button class="nav-btn" id="bt-cal" onclick="goPage('cal')"><i class="ti ti-calendar"></i>Calendar</button>
  <button class="nav-btn" id="bt-log" onclick="goPage('log')"><i class="ti ti-pencil"></i>Log</button>
  <button class="nav-btn" id="bt-ins" onclick="goPage('ins')"><i class="ti ti-chart-bar"></i>Insights</button>
  <button class="nav-btn" id="bt-settings" onclick="goPage('settings')"><i class="ti ti-settings"></i>Settings</button>
</nav>
<div class="toast" id="toast"></div>

<script>
const TODAY=new Date().toISOString().split('T')[0];
const now=new Date();
const CUR_YM=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0');
const MOS=['January','February','March','April','May','June','July','August','September','October','November','December'];
const DOW=['Su','Mo','Tu','We','Th','Fr','Sa'];
const PAGES=['home','cal','log','ins','settings'];
const TAB_COLORS={home:'#E7180B',cal:'#FFDF20',log:'#42D3F2',ins:'#2B7FFF',settings:'#999'};

const PHASES=[
  {id:'menstruation',label:'Menstruation',bg:'#E24B4A',calBg:'#F09595',calText:'#501313',icon:'ti-droplet',desc:'The uterine lining sheds. Estrogen and progesterone are at their lowest. Rest and warmth help.'},
  {id:'follicular',label:'Follicular phase',bg:'#378ADD',calBg:'#B5D4F4',calText:'#042C53',icon:'ti-leaf',desc:'Follicles mature in the ovary. Estrogen rises — energy, mood and focus are at their best.'},
  {id:'ovulation',label:'Ovulation',bg:'#1D9E75',calBg:'#9FE1CB',calText:'#04342C',icon:'ti-circle',desc:'An egg is released. Peak fertility window. Highest estrogen — you may feel confident and social.'},
  {id:'luteal',label:'Luteal phase',bg:'#534AB7',calBg:'#CECBF6',calText:'#26215C',icon:'ti-moon',desc:'Progesterone rises to prepare the uterus. Energy dips, PMS symptoms may appear near the end.'},
];

let S=null,calY=now.getFullYear(),calM=now.getMonth(),selDate=null;
let logFlow='none',logMoods=new Set(),logSyms=new Set();
let profOpen=false,unitSystem='metric';

function load(){
  try{const r=localStorage.getItem('cycle_final');S=r?JSON.parse(r):null;}catch(e){S=null;}
  if(!S){S={periods:[],logs:{},avgCycle:28,avgPeriod:5,nextId:1,profile:{name:'',age:'',height:'',weight:'',unit:'metric'}};save(true);}
  if(!S.profile)S.profile={name:'',age:'',height:'',weight:'',unit:'metric'};
  unitSystem=S.profile.unit||'metric';
  document.getElementById('today-lbl').textContent=now.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});
  renderProf();loadLogUI();renderHome();renderCal();
  document.getElementById('stxt').textContent='Data saved automatically';
}

function save(silent){try{localStorage.setItem('cycle_final',JSON.stringify(S));}catch(e){}if(!silent)toast('Saved');}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2200);}
function dsOf(d){return d.toISOString().split('T')[0];}
function addDays(ds,n){const d=new Date(ds+'T12:00:00');d.setDate(d.getDate()+n);return dsOf(d);}
function diffDays(a,b){return Math.round((new Date(b+'T12:00:00')-new Date(a+'T12:00:00'))/86400000);}
function fmtDate(ds){const d=new Date(ds+'T12:00:00');return d.toLocaleDateString('en-US',{month:'short',day:'numeric'});}
function fmtDateFull(ds){const d=new Date(ds+'T12:00:00');return d.toLocaleDateString('en-US',{month:'long',day:'numeric'});}

function calcBMI(h,w,u){const b=u==='metric'?parseFloat(w)/((parseFloat(h)/100)**2):(703*parseFloat(w))/(parseFloat(h)**2);return isNaN(b)?null:Math.round(b*10)/10;}
function bmiCat(b){if(b<18.5)return{label:'Underweight',pct:15};if(b<25)return{label:'Normal weight',pct:38};if(b<30)return{label:'Overweight',pct:62};return{label:'Obese',pct:82};}

function setUnit(u){unitSystem=u;document.getElementById('seg-m').className='seg-b'+(u==='metric'?' on':'');document.getElementById('seg-i').className='seg-b'+(u==='imperial'?' on':'');document.getElementById('h-unit').textContent=u==='metric'?'cm':'in';document.getElementById('w-unit').textContent=u==='metric'?'kg':'lbs';updateBMI();}
function updateBMI(){const h=document.getElementById('e-height').value,w=document.getElementById('e-weight').value;const p=document.getElementById('bmi-prev');if(!h||!w){p.style.display='none';return;}const bmi=calcBMI(h,w,unitSystem);if(!bmi){p.style.display='none';return;}p.style.display='block';const cat=bmiCat(bmi);const pct=Math.min(100,Math.max(0,((bmi-10)/30)*100));document.getElementById('bmi-fill').style.width=pct+'%';document.getElementById('bmi-mark').style.left=Math.min(96,pct)+'%';document.getElementById('bmi-val').textContent='BMI: '+bmi;document.getElementById('bmi-cat').textContent=cat.label;}
document.addEventListener('input',e=>{if(e.target.id==='e-height'||e.target.id==='e-weight')updateBMI();});

function toggleProf(){profOpen=!profOpen;document.getElementById('prof-edit').className='prof-edit'+(profOpen?' open':'');document.getElementById('prof-arrow').className='ti ti-chevron-down prof-arrow'+(profOpen?' open':'');if(profOpen){const p=S.profile;document.getElementById('e-name').value=p.name||'';document.getElementById('e-age').value=p.age||'';document.getElementById('e-height').value=p.height||'';document.getElementById('e-weight').value=p.weight||'';setUnit(p.unit||'metric');updateBMI();}}
function saveProf(){S.profile={name:document.getElementById('e-name').value.trim(),age:document.getElementById('e-age').value,height:document.getElementById('e-height').value,weight:document.getElementById('e-weight').value,unit:unitSystem};save(true);renderProf();toast('Profile saved!');profOpen=false;document.getElementById('prof-edit').className='prof-edit';document.getElementById('prof-arrow').className='ti ti-chevron-down prof-arrow';}
function renderProf(){const p=S.profile;const has=p.name||p.age||p.height||p.weight;document.getElementById('prof-name').textContent=p.name||'My profile';const m=[];if(p.age)m.push(p.age+' yrs');if(p.height)m.push(p.height+(p.unit==='imperial'?' in':' cm'));if(p.weight)m.push(p.weight+(p.unit==='imperial'?' lbs':' kg'));document.getElementById('prof-meta').textContent=m.length?m.join(' · '):'Tap to set up your profile';const sr=document.getElementById('prof-stats');if(has){sr.style.display='flex';const bmi=p.height&&p.weight?calcBMI(p.height,p.weight,p.unit||'metric'):null;let h='';if(p.age)h+=`<div class="ps"><div class="ps-num">${p.age}</div><div class="ps-lbl">Age</div></div>`;if(p.height)h+=`<div class="ps"><div class="ps-num">${p.height}<span style="font-size:10px;opacity:.7">${p.unit==='imperial'?' in':' cm'}</span></div><div class="ps-lbl">Height</div></div>`;if(p.weight)h+=`<div class="ps"><div class="ps-num">${p.weight}<span style="font-size:10px;opacity:.7">${p.unit==='imperial'?' lbs':' kg'}</span></div><div class="ps-lbl">Weight</div></div>`;if(bmi){const c=bmiCat(bmi);h+=`<div class="ps"><div class="ps-num">${bmi}</div><div class="ps-lbl">BMI · ${c.label}</div></div>`;}sr.innerHTML=h;}else sr.style.display='none';}

function lastPeriod(){if(!S.periods.length)return null;return[...S.periods].sort((a,b)=>b.start.localeCompare(a.start))[0];}
function getPhaseDates(cs){const cl=S.avgCycle,pl=S.avgPeriod,ov=Math.round(cl-14);return{menstruation:{start:cs,end:addDays(cs,pl-1),days:pl},follicular:{start:addDays(cs,pl),end:addDays(cs,ov-2),days:ov-1-pl},ovulation:{start:addDays(cs,ov-1),end:addDays(cs,ov),days:2},luteal:{start:addDays(cs,ov+1),end:addDays(cs,cl-1),days:cl-1-ov}};}
function calcPhase(ds){const last=lastPeriod();if(!last)return null;const day=diffDays(last.start,ds)+1;const cl=S.avgCycle,pl=S.avgPeriod,ov=Math.round(cl-14);const nd=((day-1)%cl)+1;if(nd<=pl)return{phase:'menstruation',day:nd};if(nd===ov||nd===ov+1)return{phase:'ovulation',day:nd};if(nd>pl&&nd<ov)return{phase:'follicular',day:nd};return{phase:'luteal',day:nd};}
function getActualDays(){const s=new Set();S.periods.forEach(p=>{const len=p.end?diffDays(p.start,p.end)+1:S.avgPeriod;for(let i=0;i<len;i++)s.add(addDays(p.start,i));});return s;}
function getDayClass(ds){const last=lastPeriod();if(!last)return null;const actual=getActualDays();if(actual.has(ds))return'period';const cl=S.avgCycle,pl=S.avgPeriod,ov=Math.round(cl-14);const day=diffDays(last.start,ds)+1;const nd=((day-1)%cl)+1;const cyc=Math.floor((day-1)/cl);if(cyc>=1){const cs=addDays(last.start,cyc*cl);const pp=getPhaseDates(cs);if(ds>=pp.menstruation.start&&ds<=pp.menstruation.end)return'predicted';}for(let c=1;c<=3;c++){const cs=addDays(last.start,c*cl);const pp=getPhaseDates(cs);if(ds>=pp.menstruation.start&&ds<=pp.menstruation.end)return'predicted';}if(nd<=pl)return null;if(nd===ov||nd===ov+1)return'ovulation';if(nd>pl&&nd<ov)return'follicular';if(nd>ov&&nd<=cl)return'luteal';return null;}

function renderHome(){
  const last=lastPeriod();const ph=last?calcPhase(TODAY):null;const nextC=last?addDays(last.start,S.avgCycle):null;
  let title='Your cycle',sub='Log your period to start',stats=[],pill='No data yet';
  if(ph){if(ph.phase==='menstruation'){title='Period day '+ph.day;sub='Take care of yourself today';stats=[{n:ph.day,l:'Day of period'},{n:Math.max(0,S.avgPeriod-ph.day+1),l:'Days remaining'}];pill='Menstruation';}else if(ph.phase==='follicular'){title='Follicular phase';sub='Energy rising — estrogen building';stats=[{n:ph.day,l:'Cycle day'},{n:nextC?diffDays(TODAY,nextC):'-',l:'Days to period'}];pill='Follicular phase';}else if(ph.phase==='ovulation'){title='Ovulation';sub='Peak fertility — highest estrogen';stats=[{n:ph.day,l:'Cycle day'},{n:nextC?diffDays(TODAY,nextC):'-',l:'Days to period'}];pill='Ovulation';}else{title='Luteal phase';sub='Progesterone rising — period coming';stats=[{n:ph.day,l:'Cycle day'},{n:nextC?diffDays(TODAY,nextC):'-',l:'Days to period'}];pill='Luteal phase';}}
  document.getElementById('b-title').textContent=title;document.getElementById('b-sub').textContent=sub;document.getElementById('b-pill').textContent=pill;
  document.getElementById('b-stats').innerHTML=stats.map(s=>`<div class="bstat"><div class="bstat-num">${s.n}</div><div class="bstat-lbl">${s.l}</div></div>`).join('');
  const isActive=last&&!last.end&&diffDays(last.start,TODAY)<15;
  document.getElementById('period-btn').className=isActive?'period-btn end':'period-btn';
  document.getElementById('period-btn-lbl').textContent=isActive?'Period ended today':'Period started today';
  if(last){const cur=getPhaseDates(last.start);const nxt=getPhaseDates(addDays(last.start,S.avgCycle));const up=[];PHASES.forEach(ph2=>{const c=cur[ph2.id];const n=nxt[ph2.id];const show=c.start>=TODAY?c:n;if(show.start>=TODAY)up.push({...ph2,...show});});up.sort((a,b)=>a.start.localeCompare(b.start));document.getElementById('upcoming').innerHTML=up.slice(0,4).map(u=>`<div class="dentry" style="border-top-color:rgba(0,0,0,.08)"><div class="dentry-dot" style="background:${u.bg}"></div><div><div style="display:flex;align-items:center;gap:5px;margin-bottom:2px"><span style="background:${u.bg};color:#fff;border-radius:99px;padding:1px 8px;font-size:11px">${u.label}</span></div><div style="font-size:11px;color:var(--text2)">${fmtDate(u.start)} – ${fmtDate(u.end)} · In ${diffDays(TODAY,u.start)} days · ${u.days} days</div></div></div>`).join('')||'<div class="empty-d">No upcoming phases</div>';}else document.getElementById('upcoming').innerHTML='<div class="empty-d">Log your period to see phases</div>';
  renderTodayLog();
}

function renderTodayLog(){const log=S.logs[TODAY];const el=document.getElementById('today-log');if(!log){el.innerHTML='<div class="empty-d">Nothing logged today</div>';return;}let h='';if(log.flow&&log.flow!=='none')h+=`<div style="font-size:13px;margin-bottom:5px"><span style="color:var(--text2)">Flow:</span> ${log.flow}</div>`;if(log.moods&&log.moods.length)h+=`<div style="font-size:13px;margin-bottom:5px"><span style="color:var(--text2)">Mood:</span> ${log.moods.join(', ')}</div>`;if(log.symptoms&&log.symptoms.length)h+=`<div style="font-size:13px;margin-bottom:5px"><span style="color:var(--text2)">Symptoms:</span> ${log.symptoms.join(', ')}</div>`;if(log.note)h+=`<div style="font-size:13px;color:var(--text2);font-style:italic">"${log.note}"</div>`;el.innerHTML=h||'<div class="empty-d">Nothing logged today</div>';}

function togglePeriod(){const last=lastPeriod();const isActive=last&&!last.end&&diffDays(last.start,TODAY)<15;if(isActive){last.end=TODAY;S.avgPeriod=Math.round(S.avgPeriod*.7+(diffDays(last.start,TODAY)+1)*.3);toast('Period ended!');}else{if(last){const nc=diffDays(last.start,TODAY);if(nc>=20&&nc<=45)S.avgCycle=Math.round(S.avgCycle*.7+nc*.3);}S.periods.push({id:S.nextId++,start:TODAY,end:null});toast('Period started!');}save(true);renderHome();renderCal();}

function loadLogUI(){const log=S.logs[TODAY]||{};logFlow=log.flow||'none';logMoods=new Set(log.moods||[]);logSyms=new Set(log.symptoms||[]);updateFlowUI();updateMoodUI();updateSymUI();document.getElementById('log-note').value=log.note||'';}
function setFlow(f){logFlow=f;updateFlowUI();}
function updateFlowUI(){['none','light','medium','heavy'].forEach(f=>{const el=document.getElementById('fl-'+f);if(el)el.className='fl-btn'+(logFlow===f?' on':'');});}
function togMood(m){logMoods.has(m)?logMoods.delete(m):logMoods.add(m);updateMoodUI();}
function updateMoodUI(){['happy','calm','tired','anxious','sad','irritable','sensitive','energetic'].forEach(m=>{const el=document.getElementById('md-'+m);if(el)el.className='mood-btn'+(logMoods.has(m)?' on':'');});}
function togSym(s){logSyms.has(s)?logSyms.delete(s):logSyms.add(s);updateSymUI();}
function updateSymUI(){['cramps','headache','bloating','backpain','nausea','breast','acne','spotting','insomnia','cravings'].forEach(s=>{const el=document.getElementById('sy-'+s);if(el)el.className='chip'+(logSyms.has(s)?' on':'');});}
function saveLog(){S.logs[TODAY]={flow:logFlow,moods:[...logMoods],symptoms:[...logSyms],note:document.getElementById('log-note').value.trim(),date:TODAY};if(logFlow!=='none'){const hasP=S.periods.some(p=>diffDays(p.start,TODAY)>=0&&(!p.end||diffDays(TODAY,p.end)>=0));if(!hasP){const last=lastPeriod();if(!last||diffDays(last.start,TODAY)>3){if(last){const nc=diffDays(last.start,TODAY);if(nc>=20&&nc<=45)S.avgCycle=Math.round(S.avgCycle*.7+nc*.3);}S.periods.push({id:S.nextId++,start:TODAY,end:null});}}}save(true);renderHome();renderCal();renderIns();toast('Log saved!');goPage('home');}

function renderCal(){
  const first=new Date(calY,calM,1).getDay();const dim=new Date(calY,calM+1,0).getDate();const prev=new Date(calY,calM,0).getDate();const actual=getActualDays();
  document.getElementById('cal-mo').textContent=MOS[calM]+' '+calY;
  const g=document.getElementById('cgrid');g.innerHTML='';
  DOW.forEach(d=>{const el=document.createElement('div');el.className='cdow';el.textContent=d;g.appendChild(el);});
  for(let i=0;i<first;i++){const el=document.createElement('div');el.className='cday om';el.innerHTML='<span class="dno">'+(prev-first+1+i)+'</span>';g.appendChild(el);}
  for(let d=1;d<=dim;d++){const ds=calY+'-'+String(calM+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');const el=document.createElement('div');let cls='cday';if(ds===TODAY)cls+=' tod';if(ds===selDate)cls+=' sel';const type=actual.has(ds)?'period':getDayClass(ds);if(type)cls+=' '+type;el.className=cls;el.innerHTML='<span class="dno">'+d+'</span>';if(S.logs[ds]){const dot=document.createElement('div');dot.className='cdot';el.appendChild(dot);}el.onclick=()=>{selDate=ds;renderCal();showCalDay(ds);};g.appendChild(el);}
  const rem=(7-((first+dim)%7))%7;for(let i=1;i<=rem;i++){const el=document.createElement('div');el.className='cday om';el.innerHTML='<span class="dno">'+i+'</span>';g.appendChild(el);}
  renderPhaseInfo();
}

function renderPhaseInfo(){const wrap=document.getElementById('phase-info');const last=lastPeriod();if(!last){wrap.innerHTML='<div class="empty">Log your period to see phase dates</div>';return;}const cur=getPhaseDates(last.start);const nxt=getPhaseDates(addDays(last.start,S.avgCycle));let html='';PHASES.forEach(ph=>{const c=cur[ph.id];const n=nxt[ph.id];const isNow=TODAY>=c.start&&TODAY<=c.end;const show=isNow||c.start>TODAY?c:n;const dayIn=isNow?diffDays(c.start,TODAY)+1:null;const dayLeft=isNow?diffDays(TODAY,c.end):null;html+=`<div class="pc"><div class="pc-icon"><i class="ti ${ph.icon}" style="color:#fff;font-size:17px"></i></div><div style="flex:1"><div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap"><div class="pc-name">${ph.label}</div>${isNow?'<span style="background:rgba(255,255,255,.9);color:#B0006B;font-size:10px;font-weight:500;padding:2px 8px;border-radius:99px">Active now</span>':''}</div><div class="pc-dates">${fmtDateFull(show.start)} – ${fmtDateFull(show.end)} · ${show.days} day${show.days!==1?'s':''}</div>${isNow?`<div class="pc-active">Day ${dayIn} of ${c.days} · ${dayLeft} day${dayLeft!==1?'s':''} left</div>`:''}<div class="pc-desc">${ph.desc}</div></div></div>`;});wrap.innerHTML=html;}

function showCalDay(ds){const wrap=document.getElementById('cal-detail');const d=new Date(ds+'T12:00:00');const label=d.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'});const log=S.logs[ds];const ph=lastPeriod()?calcPhase(ds):null;const phInfo=ph?PHASES.find(p=>p.id===ph.phase):null;let h=`<div style="background:#FDA5D5;border-radius:var(--r);margin-bottom:12px;overflow:hidden"><div style="padding:12px 15px;border-bottom:0.5px solid rgba(107,0,64,.2);font-size:13px;font-weight:500;color:#6B0040;display:flex;align-items:center;gap:6px"><i class="ti ti-calendar-event"></i>${label}</div><div style="padding:13px 15px">`;if(phInfo)h+=`<div style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.6);color:${phInfo.calText};border-radius:10px;padding:6px 12px;font-size:12px;font-weight:500;margin-bottom:10px"><i class="ti ${phInfo.icon}"></i>${phInfo.label} · day ${ph.day}</div>`;if(log){if(log.flow&&log.flow!=='none')h+=`<div style="font-size:13px;margin-bottom:4px"><span style="color:#8B0050">Flow:</span> <span style="color:#6B0040">${log.flow}</span></div>`;if(log.moods&&log.moods.length)h+=`<div style="font-size:13px;margin-bottom:4px"><span style="color:#8B0050">Mood:</span> <span style="color:#6B0040">${log.moods.join(', ')}</span></div>`;if(log.symptoms&&log.symptoms.length)h+=`<div style="font-size:13px;margin-bottom:4px"><span style="color:#8B0050">Symptoms:</span> <span style="color:#6B0040">${log.symptoms.join(', ')}</span></div>`;if(log.note)h+=`<div style="font-size:13px;color:#8B0050;font-style:italic;margin-top:5px">"${log.note}"</div>`;}else h+='<div style="font-size:13px;color:#8B0050">No log for this day</div>';h+='</div></div>';wrap.innerHTML=h;}
function shiftCal(d){calM+=d;if(calM>11){calM=0;calY++;}if(calM<0){calM=11;calY--;}document.getElementById('cal-detail').innerHTML='';selDate=null;renderCal();}

function renderIns(){const wrap=document.getElementById('ins-content');if(!S.periods.length){wrap.innerHTML='<div class="empty-d">Log at least one period to see insights</div>';return;}const allS={},allM={};const logs=Object.values(S.logs);const lc=logs.length;logs.forEach(l=>{(l.symptoms||[]).forEach(s=>allS[s]=(allS[s]||0)+1);(l.moods||[]).forEach(m=>allM[m]=(allM[m]||0)+1);});const topS=Object.entries(allS).sort((a,b)=>b[1]-a[1]).slice(0,4);const topM=Object.entries(allM).sort((a,b)=>b[1]-a[1]).slice(0,4);const p=S.profile;const bmi=p.height&&p.weight?calcBMI(p.height,p.weight,p.unit||'metric'):null;let h=`<div class="ins-panel" style="margin-bottom:12px"><div class="ins-panel-body"><div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px"><div style="background:rgba(255,255,255,.2);border-radius:10px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:500;color:#fff">${S.avgCycle}</div><div style="font-size:11px;color:rgba(255,255,255,.8);margin-top:2px">Avg cycle</div></div><div style="background:rgba(255,255,255,.2);border-radius:10px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:500;color:#fff">${S.avgPeriod}</div><div style="font-size:11px;color:rgba(255,255,255,.8);margin-top:2px">Avg period</div></div><div style="background:rgba(255,255,255,.2);border-radius:10px;padding:12px;text-align:center"><div style="font-size:22px;font-weight:500;color:#fff">${lc}</div><div style="font-size:11px;color:rgba(255,255,255,.8);margin-top:2px">Days logged</div></div></div></div></div>`;if(bmi){const cat=bmiCat(bmi);h+=`<div class="ins-panel" style="margin-bottom:12px"><div class="ins-panel-head"><i class="ti ti-scale"></i>Body stats</div><div class="ins-panel-body"><div style="display:flex;gap:8px">${p.age?`<div style="background:rgba(255,255,255,.2);border-radius:10px;padding:10px 12px;flex:1;text-align:center"><div style="font-size:18px;font-weight:500;color:#fff">${p.age}</div><div style="font-size:11px;color:rgba(255,255,255,.8)">Age</div></div>`:''}<div style="background:rgba(255,255,255,.2);border-radius:10px;padding:10px 12px;flex:1;text-align:center"><div style="font-size:18px;font-weight:500;color:#fff">${bmi}</div><div style="font-size:11px;color:rgba(255,255,255,.8)">BMI</div></div><div style="background:rgba(255,255,255,.2);border-radius:10px;padding:10px 12px;flex:1;text-align:center"><div style="font-size:13px;font-weight:500;color:#fff">${cat.label}</div><div style="font-size:11px;color:rgba(255,255,255,.8)">Category</div></div></div></div></div>`;}if(topS.length){h+=`<div class="ins-panel" style="margin-bottom:12px"><div class="ins-panel-head"><i class="ti ti-activity"></i>Top symptoms</div><div class="ins-panel-body">`;topS.forEach(([sym,cnt])=>{const pct=lc?Math.round(cnt/lc*100):0;h+=`<div style="margin-bottom:9px"><div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:3px"><span style="color:#fff">${sym}</span><span style="color:rgba(255,255,255,.75)">${cnt} days</span></div><div class="prog-bar"><div class="prog-fill" style="width:${pct}%;background:rgba(255,255,255,.7)"></div></div></div>`;});h+='</div></div>';}if(topM.length){h+=`<div class="ins-panel" style="margin-bottom:12px"><div class="ins-panel-head"><i class="ti ti-mood-smile"></i>Common moods</div><div class="ins-panel-body"><div style="display:flex;flex-wrap:wrap;gap:7px">`;topM.forEach(([mood,cnt])=>{h+=`<div style="padding:6px 13px;background:rgba(255,255,255,.2);border:0.5px solid rgba(255,255,255,.4);color:#fff;border-radius:99px;font-size:12px">${mood} · ${cnt}x</div>`;});h+='</div></div></div>';}h+=`<div class="ins-panel"><div class="ins-panel-head"><i class="ti ti-history"></i>Period history</div><div class="ins-panel-body">`;[...S.periods].reverse().slice(0,6).forEach(p=>{const len=p.end?diffDays(p.start,p.end)+1:'ongoing';h+=`<div class="dentry"><div class="dentry-dot" style="background:rgba(255,255,255,.8)"></div><div><div class="dentry-date">${fmtDate(p.start)}</div><div class="dentry-sub">${typeof len==='number'?len+' days':len}${p.end?' · ended '+fmtDate(p.end):''}</div></div></div>`;});h+='</div></div>';wrap.innerHTML=h;}

function exportData(){const blob=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='cycle-backup-'+TODAY+'.json';a.click();URL.revokeObjectURL(url);toast('Backup downloaded!');}
function importData(event){const file=event.target.files[0];if(!file)return;const reader=new FileReader();reader.onload=e=>{try{const data=JSON.parse(e.target.result);if(!data.periods||!data.logs)throw new Error();localStorage.setItem('cycle_final',JSON.stringify(data));toast('Imported! Reloading...');setTimeout(()=>location.reload(),1500);}catch(err){toast('Invalid file!');}};reader.readAsText(file);event.target.value='';}
function saveMonth(){const logDays=Object.keys(S.logs).filter(ds=>ds.startsWith(CUR_YM));if(!logDays.length){toast('No data to save for this month.');return;}const arc={label:MOS[now.getMonth()]+' '+now.getFullYear(),ym:CUR_YM,logs:{},periods:[],savedAt:new Date().toISOString()};logDays.forEach(ds=>{arc.logs[ds]=S.logs[ds];});arc.periods=S.periods.filter(p=>p.start.startsWith(CUR_YM));try{localStorage.setItem('arc_'+CUR_YM,JSON.stringify(arc));const idxRaw=localStorage.getItem('arc_idx');const idx=idxRaw?JSON.parse(idxRaw):[];if(!idx.includes(CUR_YM))idx.unshift(CUR_YM);localStorage.setItem('arc_idx',JSON.stringify(idx));logDays.forEach(ds=>{delete S.logs[ds];});save(true);renderHome();renderCal();renderArc();toast('Month saved! Calendar cleared.');}catch(e){toast('Save failed!');}}
function renderArc(){const wrap=document.getElementById('arc-list');if(!wrap)return;const idxRaw=localStorage.getItem('arc_idx');const idx=idxRaw?JSON.parse(idxRaw):[];if(!idx.length){wrap.innerHTML='<div class="empty-d">No archived months yet</div>';return;}let h='';idx.forEach(ym=>{try{const arc=JSON.parse(localStorage.getItem('arc_'+ym));const lc=Object.keys(arc.logs||{}).length;h+=`<div class="arc-item"><div><div class="arc-mo">${arc.label}</div><div class="arc-meta">${lc} days logged · ${arc.periods?.length||0} periods</div></div><i class="ti ti-check-circle" style="font-size:20px;color:#1D9E75"></i></div>`;}catch(e){}});wrap.innerHTML=h||'<div class="empty-d">No archived months yet</div>';}

function goPage(p){
  PAGES.forEach(x=>{
    document.getElementById('pg-'+x).className='pg'+(p===x?' on':'');
    const btn=document.getElementById('bt-'+x);const c=TAB_COLORS[x]||'#999';
    if(p===x){btn.style.color=c;btn.querySelector('i').style.color=c;}
    else{btn.style.color='';btn.querySelector('i').style.color='';}
  });
  if(p==='ins')renderIns();if(p==='cal')renderCal();if(p==='log')loadLogUI();if(p==='settings')renderArc();
  window.scrollTo(0,0);
}

if('serviceWorker' in navigator){window.addEventListener('load',()=>{const sw=`self.addEventListener('install',e=>self.skipWaiting());self.addEventListener('activate',e=>clients.claim());self.addEventListener('fetch',e=>{if(e.request.mode==='navigate'){e.respondWith(fetch(e.request).catch(()=>caches.match('/')));}else{e.respondWith(caches.match(e.request).then(r=>r||fetch(e.request)));}});`;const blob=new Blob([sw],{type:'application/javascript'});const url=URL.createObjectURL(blob);navigator.serviceWorker.register(url).catch(()=>{});});}

load();
</script>
